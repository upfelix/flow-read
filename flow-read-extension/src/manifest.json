{
  "manifest_version": 3,
  "name": "FlowRead",
  "version": "1.0.0",
  "description": "Zero-distraction reading and highlighting extension",
  "action": {
    "default_title": "Enable FlowRead"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "scripting"
  ],
  "options_ui": {
    "page": "src/pages/options/index.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "<all_urls>",
    "https://api.notion.com/*"
  ]
}
